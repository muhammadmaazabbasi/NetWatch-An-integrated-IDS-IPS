# NetWatch environment configuration
# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Flask session signing key. Use a long random string in production.
SECRET_KEY=change_me_to_a_random_secret

# Threat intelligence (optional) — queried after HIGH/MEDIUM alerts on public IPs
# No spaces after the equals sign.
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
VIRUSTOTAL_API_KEY=your_virustotal_key_here
